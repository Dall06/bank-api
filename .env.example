# ============================================================================
# Bank API - Global Environment Variables
# ============================================================================

ENV=development
LOG_LEVEL=info
SERVICE_NAME=bank-api
PORT=8080

# Database Config (Used by users & transactions)
DATABASE_URL=postgres://base_user:base_password@localhost:5432/base_db?sslmode=disable
MAX_POOL_CONNECTIONS=10
MAX_IDLE_CONNECTIONS=5
CONNECTION_MAX_LIFETIME=3600

# Security Keys
JWT_SECRET=super-secret-key-change-me
SIGIL_SECRET=super-secret-sigil-key
ALLOWED_SERVICES=gateway,transactions,crons

# Data Encryption in Rest (AES-256-GCM keys)
ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
HMAC_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# Event Streaming & Cache
REDIS_URL=localhost:6379
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=transaction-completed

# Service URLs (Local testing defaults)
USERS_URL=http://localhost:8081
TRANSACTIONS_URL=http://localhost:8082

# Internal Service-to-Service URLs
USERS_INTERNAL_URL=http://localhost:8081/internal/users
TRANSACTIONS_INTERNAL_URL=http://localhost:8082/internal/transactions
PROVIDER_EXECUTE_URL=http://localhost:8083/provider/v1/execute

# CORS Allowed Origins (Used by gateway)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Evaluator mode: set false to disable JWT validation (optional users service)
AUTH_REQUIRED=true
